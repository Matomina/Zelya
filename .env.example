# JWT — generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_GENERATE_STRONG_SECRET_64_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=30

